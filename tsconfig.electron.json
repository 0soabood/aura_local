{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist-electron",
    "sourceMap": true
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/db/**/*.ts",
    "src/lib/**/*.ts",
    "src/shared/**/*.ts"
  ],
  "exclude": ["node_modules", "**/*.test.ts"]
}