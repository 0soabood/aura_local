{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-main",
    "module": "CommonJS",
    "target": "ESNext",
    "moduleResolution": "node",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/main/**/*", "src/db/**/*", "src/shared/**/*"]
}
